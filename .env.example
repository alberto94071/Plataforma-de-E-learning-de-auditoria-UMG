# =============================================
# AUDITPRO - Environment Variables
# Copy this file to .env.local
# =============================================

# Neon PostgreSQL (from neon.tech dashboard)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/auditoria?sslmode=require"

# NextAuth v5
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-random-secret-here"

# Optional: Full URL for production (set on Vercel env vars)
NEXTAUTH_URL="https://your-domain.vercel.app"
